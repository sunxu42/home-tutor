# Server environment variables (copy to .env)
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173"]
DATA_DIR=data
# Filesystem root for session review data (meta.json, packages/, tutor/)
SESSION_FIXTURES_ROOT=tests/fixtures/sessions

# LLM — global strategy
LLM_ACTIVE_PROVIDER=deepseek
# Save-token mode (live sessions only):
#   true  — do not prefetch or auto-analyze; user clicks「AI 分析」to call LLM
#   false — auto-analyze on view and prefetch wrong answers when selecting timeline segments
# Mock/fixture sessions always use manual-only LLM regardless of this flag.
LLM_SAVE_TOKEN_MODE=false
# Legacy: skip replacing ready on-disk tutor files during automatic scheduling (live)
LLM_SKIP_FIXTURE_TUTOR=true
LLM_REQUEST_TIMEOUT_SEC=120

# Named providers (prefix: LLM_PROVIDER_{NAME}_*)
# BASE_URL should be the API root only; client appends /chat/completions.
LLM_PROVIDER_DEEPSEEK_API_KEY=
LLM_PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_PROVIDER_DEEPSEEK_MODEL=deepseek-chat

LLM_PROVIDER_OPENAI_API_KEY=
LLM_PROVIDER_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER_OPENAI_MODEL=gpt-4o-mini

# Example: LLM_ACTIVE_PROVIDER=glm
LLM_PROVIDER_GLM_API_KEY=
LLM_PROVIDER_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_PROVIDER_GLM_MODEL=glm-4-flash

# Langfuse — LLM observability (https://langfuse.com)
# Leave keys empty to disable tracing.
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000

# Logging — milestone: AI milestones only | verbose: +HTTP/prompt summary | debug: all
LOG_MODE=milestone
LOG_DIR=data/logs
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true
LOG_RETENTION_DAYS=30
LOG_LLM_VERBOSE=true

# Alibaba Cloud NLS — Speech Gateway (ASR/TTS)
ALIYUN_SPEECH_APP_KEY=
# Optional: short-lived token from NLS console. If empty, AccessKey pair is used.
ALIYUN_SPEECH_TOKEN=
ALIYUN_SPEECH_ACCESS_KEY_ID=
ALIYUN_SPEECH_ACCESS_KEY_SECRET=
ALIYUN_SPEECH_REGION=cn-shanghai
ALIYUN_SPEECH_GATEWAY_URL=wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1
ALIYUN_SPEECH_TTS_VOICE=xiaoyun
ALIYUN_SPEECH_TTS_FORMAT=pcm
ALIYUN_SPEECH_TTS_SAMPLE_RATE=16000

# HMAC secret for short-lived speech WebSocket tokens (GET /api/speech/ws-token)
# In DEBUG mode, a dev fallback is used when this is empty.
SPEECH_WS_SECRET=
