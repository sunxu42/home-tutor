{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "home-tutor.session-meta.v1",
  "title": "SessionMeta",
  "description": "Slim session header; prompts and layout live in per-question packages.",
  "type": "object",
  "required": ["schema_version", "session_id", "started_at", "ended_at", "questions", "status"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "home-tutor.session-meta.v1"
    },
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "grade_level": {
      "type": "string",
      "enum": ["primary"]
    },
    "subject": {
      "type": "string",
      "enum": ["math"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "pages": {
      "type": "array",
      "items": { "$ref": "#/$defs/page" }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/question_ref" }
    },
    "status": {
      "type": "string",
      "enum": ["building", "complete"]
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "required": ["page_id", "index"],
      "additionalProperties": false,
      "properties": {
        "page_id": { "type": "string" },
        "index": { "type": "integer", "minimum": 1 }
      }
    },
    "question_ref": {
      "type": "object",
      "required": ["question_id", "page_id", "index_on_page", "number"],
      "additionalProperties": false,
      "properties": {
        "question_id": { "type": "string" },
        "page_id": { "type": "string" },
        "index_on_page": { "type": "integer", "minimum": 1 },
        "number": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
