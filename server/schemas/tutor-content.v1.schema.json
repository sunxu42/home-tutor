{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "home-tutor.tutor-content.v1",
  "title": "TutorContent",
  "description": "Per-question tutoring copy from LLM or mock generator.",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "question_id",
    "analysis_status",
    "verdict",
    "reference_answer",
    "summary",
    "explanation_paragraphs"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "home-tutor.tutor-content.v1"
    },
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "question_id": {
      "type": "string"
    },
    "analysis_status": {
      "type": "string",
      "enum": ["missing", "pending", "generating", "ready", "failed"]
    },
    "verdict": {
      "type": "string",
      "enum": ["correct", "wrong", "unknown"]
    },
    "reference_answer": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "explanation_paragraphs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "error_classification": {
      "$ref": "#/$defs/error_classification"
    },
    "process_comment": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    },
    "stale": {
      "type": "boolean"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "model": {
      "type": "string"
    },
    "error": {
      "type": ["string", "null"]
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "required": ["id", "label", "enabled"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "enabled": { "type": "boolean" }
      }
    },
    "error_classification": {
      "type": "object",
      "required": ["category"],
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "correct",
            "concept_error",
            "calculation_error",
            "incomplete",
            "unknown"
          ]
        },
        "subcategory": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
