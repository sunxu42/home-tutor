# API base URL (defaults to /api; Vite dev server proxies to backend)
# VITE_API_BASE=/api

# Optional CopilotKit Intelligence license key (free at https://dashboard.operations.copilotkit.ai)
# VITE_COPILOTKIT_LICENSE_KEY=

# Optional override for speech websocket (defaults to same host /ws/speech)
# VITE_SPEECH_WS_URL=ws://localhost:8000/ws/speech
